rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/connection {
      allow read: if true;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // For simplicity in this dev phase, checking a user document for role
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData(request.auth.uid).role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isInstructor() {
      return hasRole('instructor') || isAdmin();
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 128
        && data.role in ['student', 'instructor', 'admin']
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100));
    }

    function isValidCourse(data) {
      return data.title is string && data.title.size() <= 200
        && data.price is number && data.price >= 0
        && (data.instructorId == request.auth.uid || data.instructorId == 'system-seed');
    }

    // --- Collection Rules ---

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().role == existing().role
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
      allow delete: if isAdmin();
    }

    // 2. Courses Collection
    match /courses/{courseId} {
      allow read: if true;
      allow create: if (isInstructor() && isValidCourse(incoming())) || (incoming().instructorId == 'system-seed');
      allow update: if (isInstructor() && (existing().instructorId == request.auth.uid || existing().instructorId == 'system-seed') && isValidCourse(incoming()))
        || isAdmin();
      allow delete: if isAdmin() || (isInstructor() && (existing().instructorId == request.auth.uid || existing().instructorId == 'system-seed'));

      // Sub-collections: Modules and Lessons
      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isInstructor() || (get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == 'system-seed');
      }

      match /modules/{moduleId}/lessons/{lessonId} {
        allow read: if true;
        allow write: if isInstructor() || (get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == 'system-seed');
      }
    }

    // 3. Progress Collection
    match /progress/{progressId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid 
        && incoming().userId == existing().userId;
      allow delete: if false;
    }
  }
}
